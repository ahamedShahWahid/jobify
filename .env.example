# Jobify API local environment example.
# Copy to .env and fill in real values; .env is git-ignored.

JOBIFY_ENV=local
JOBIFY_LOG_LEVEL=INFO
JOBIFY_LOG_FORMAT=text          # text | json
JOBIFY_SERVICE_NAME=jobify-api
JOBIFY_DB_URL=postgresql+asyncpg://jobify:jobify@localhost:5432/jobify

# Resume upload (from P1.0)
JOBIFY_STORAGE_ROOT=var/uploads
JOBIFY_MAX_UPLOAD_BYTES=10485760
JOBIFY_ALLOWED_RESUME_CONTENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Auth / JWT
JOBIFY_JWT_SECRET=replace-with-32+-byte-random-string-from-openssl-rand-base64-32
JOBIFY_JWT_ACCESS_TTL_SECONDS=600
JOBIFY_JWT_REFRESH_TTL_SECONDS=2592000

# Google OAuth — CSV of accepted client IDs (web, iOS, Android registered in GCP console)
JOBIFY_GOOGLE_OAUTH_CLIENT_IDS=YOUR_CLIENT_ID.apps.googleusercontent.com
JOBIFY_GOOGLE_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
JOBIFY_GOOGLE_JWKS_CACHE_TTL_SECONDS=3600

# Auth policy
JOBIFY_AUTH_REQUIRE_EMAIL_VERIFIED=false

# CORS — CSV of browser origins allowed to call the API (the Flutter web dev
# server). Mobile clients send no Origin header, so this only gates web.
JOBIFY_CORS_ALLOW_ORIGINS=http://localhost:8080

# Background workers (Celery + Redis)
JOBIFY_REDIS_URL=redis://localhost:6379/0
JOBIFY_CELERY_TASK_ALWAYS_EAGER=false

# Embedding worker (Gemini)
JOBIFY_GEMINI_API_KEY=changeme
JOBIFY_EMBEDDING_MODEL=gemini-embedding-2
JOBIFY_EMBEDDING_DIM=1536

# --- Notifications ---
# Email channel backend: logging (stub, dev/MVP) or ses (real AWS SES, prod).
JOBIFY_EMAIL_CHANNEL=logging
# Max notifications the sweeper claims per pass (1-1000).
JOBIFY_NOTIFY_BATCH_SIZE=50

# --- Scoring ---
# Total score >= this surfaces a match in the feed (range 0.0-1.0).
JOBIFY_MATCH_SURFACE_THRESHOLD=0.55
# Weight on the vector component; structured = 1 - this (range 0.0-1.0).
JOBIFY_MATCH_VECTOR_WEIGHT=0.6

# --- Match explainer ---
# 'templated' (default; deterministic, no network) or 'llm' (Gemini text-gen).
JOBIFY_MATCH_EXPLAINER=templated
# Gemini text model used when JOBIFY_MATCH_EXPLAINER=llm. Ignored otherwise.
JOBIFY_MATCH_EXPLAINER_MODEL=gemini-2.5-flash
