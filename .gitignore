# macOS Finder metadata. Created any time you open a folder in Finder.
.DS_Store
._*

# Local upload storage (LocalFileStorage root — lives under whichever package
# owns storage; currently core/var/). Match any package's var/ dir.
**/var/

# Local secrets scratch files (Gemini key, JWT secret, DB password, etc.) — never
# commit. `.env` holds live values; `.env.example` is the tracked template.
.env
keys.txt
working

# Redis dump produced by a local redis-server.
*.rdb

# Playwright MCP verification artifacts (screenshots, console logs).
.playwright-mcp/

# Project-local Git worktrees used for isolated implementation sessions.
.worktrees/
.superpowers/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
