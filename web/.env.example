# Jobify Web — copy to `.env.local` (gitignored) and fill in.

# Google Web OAuth client id (*.apps.googleusercontent.com). Enables the
# "Continue with Google" button on the Explore gate. If unset, the gate shows a
# muted hint instead and demo + paste-token sign-in still work.
VITE_GOOGLE_CLIENT_ID=

# API base for the Google-token exchange and live calls. Defaults to
# http://localhost:8000 when unset.
VITE_API_BASE_URL=http://localhost:8000
