# Jobify Console — Vite build-time env (copy to `.env`, baked at `vite build`).

# Google **Web** OAuth client id (*.apps.googleusercontent.com).
# Unset ⇒ the sign-in screen hides the Google button and shows a muted hint;
# demo + paste-token sign-in still work.
VITE_GOOGLE_CLIENT_ID=

# API base URL used for the Google ID-token exchange and live console calls.
VITE_API_BASE_URL=http://localhost:8000
